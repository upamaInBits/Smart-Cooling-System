<?xml version="1.0" encoding="utf-8"?>
<System>
  <P Name="Location">[457, 199, 1633, 949]</P>
  <P Name="ZoomFactor">59</P>
  <Block BlockType="Inport" Name="u" SID="206">
    <P Name="Position">[15, 158, 45, 172]</P>
    <P Name="ZOrder">-1</P>
  </Block>
  <Block BlockType="SubSystem" Name="Initialize variables" SID="207">
    <PortCounts/>
    <P Name="Position">[280, 16, 345, 47]</P>
    <P Name="ZOrder">-2</P>
    <P Name="ForegroundColor">blue</P>
    <P Name="DropShadow">on</P>
    <P Name="ShowName">off</P>
    <P Name="Priority">-10</P>
    <P Name="OpenFcn">try                                                            
     clearvars -except inifile pathfile_in pathfile_pos posfile
     cd(pathfile_in);                                          
     eval(inifile);                                            
catch                                                          
     [inifile,pathfile_in] = getInitializationfile;            
     cd(pathfile_in);                                          
     inifile = strrep(inifile,&apos;.m&apos;,&apos;&apos;);                        
     eval(inifile);                                            
end                                                            </P>
    <Mask>
      <Display>disp(&apos;Double Click\n to Initialize&apos;)</Display>
    </Mask>
    <System Ref="system_207"/>
  </Block>
  <Block BlockType="SubSystem" Name="Integrator System" SID="208">
    <PortCounts in="4" out="4"/>
    <P Name="Position">[210, 112, 325, 423]</P>
    <P Name="ZOrder">-3</P>
    <P Name="Priority">2</P>
    <Mask>
      <Type>Hybrid Integrator</Type>
      <Display/>
      <Description>This block integrates the state of the hybrid system defined by the flow map f (first input), the flow set C (second input), the jump map g (third input) and the jump set D (fourth input).
Starting from the initial condition x0 (last mask parameter), the system&apos;s state x evolves continuously within the set C, according to f(x,u), but is also subject to jumps within D, according to g(x,u).
The block also stops the simulation when the time t is greater than the flow horizon T (first mask parameter), or when the number of jumps j is greater than the jump horizon J (second mask parameter).
The outputs of the blocks are respectively x(t), t, j, x(t-).</Description>
      <Help>This block integrates the state of the hybrid system defined by the flow map f (first input), the flow set C (second input), the jump map g (third input) and the jump set D (fourth input).
&lt;br&gt;
Starting from the initial condition x0 (last mask parameter), the system&apos;s state x evolves continuously within the set C, according to f(x,u), but is also subject to jumps within D, according to g(x,u).
&lt;br&gt;
The block also stops the simulation when the time t is greater than the flow horizon T (first mask parameter), or when the number of jumps j is greater than the jump horizon J (second mask parameter).
&lt;br&gt;
The outputs of the blocks are respectively x(t), t, j, x(t-).
&lt;br&gt;
You can right click on the block and &quot;Look under mask&quot; to see what&apos;s inside the block. 
Finally, refer to the manual (HybridSimulator_vXX.pdf) for more detailed information on how this hybrid simulator works.
</Help>
      <MaskParameter Name="T" Type="edit">
        <Prompt>Flow Horizon</Prompt>
        <Value>T</Value>
      </MaskParameter>
      <MaskParameter Name="J" Type="edit">
        <Prompt>Jump Horizon</Prompt>
        <Value>J</Value>
      </MaskParameter>
      <MaskParameter Name="x0" Type="edit">
        <Prompt>Initial Condition</Prompt>
        <Value>x0</Value>
      </MaskParameter>
    </Mask>
    <System Ref="system_208"/>
  </Block>
  <Block BlockType="SubSystem" Name="Plot Solutions" SID="260">
    <PortCounts/>
    <P Name="Position">[390, 16, 472, 48]</P>
    <P Name="ZOrder">-4</P>
    <P Name="ForegroundColor">blue</P>
    <P Name="DropShadow">on</P>
    <P Name="ShowName">off</P>
    <P Name="OpenFcn">try                                                 
     cd(pathfile_pos);                              
     eval(posfile);                                 
catch                                               
     [posfile,pathfile_pos] = getInitializationfile;
     cd(pathfile_pos);                              
     posfile = strrep(posfile,&apos;.m&apos;,&apos;&apos;);             
     eval(posfile);                                 
end                                                 </P>
    <Mask>
      <Display>disp(&apos;Double Click to\n Plot Solutions&apos;)</Display>
    </Mask>
    <System Ref="system_260"/>
  </Block>
  <Block BlockType="SubSystem" Name="flow map f" SID="261">
    <PortCounts in="3" out="1"/>
    <P Name="Position">[115, 137, 175, 173]</P>
    <P Name="ZOrder">-5</P>
    <P Name="ErrorFcn">Stateflow.Translate.translate</P>
    <P Name="PermitHierarchicalResolution">ExplicitOnly</P>
    <P Name="TreatAsAtomicUnit">on</P>
    <P Name="SFBlockType">MATLAB Function</P>
    <PortProperties>
      <Port Type="out" Index="1">
        <P Name="PropagatedSignals">xdot</P>
      </Port>
    </PortProperties>
    <System Ref="system_261"/>
  </Block>
  <Block BlockType="SubSystem" Name="flow set C" SID="262">
    <PortCounts in="2" out="1"/>
    <P Name="Position">[115, 212, 175, 248]</P>
    <P Name="ZOrder">-6</P>
    <P Name="ErrorFcn">Stateflow.Translate.translate</P>
    <P Name="PermitHierarchicalResolution">ExplicitOnly</P>
    <P Name="TreatAsAtomicUnit">on</P>
    <P Name="SFBlockType">MATLAB Function</P>

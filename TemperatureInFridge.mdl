        <DialogControl Type="Text" Name="DescTextVar">
          <Prompt>%&lt;MaskDescription&gt;</Prompt>
        </DialogControl>
        <DialogControl Type="Hyperlink" Name="Control2">
          <Prompt>CPS Components Documentation</Prompt>
          <Callback>hybrid.internal.openHelp(&apos;CPS_Components&apos;)</Callback>
        </DialogControl>
        <DialogControl Type="Group" Name="Container4">
          <Prompt>Configuration</Prompt>
          <DialogControl Type="Edit" Name="q0">
            <Prompt>Initial state (column vector)</Prompt>
          </DialogControl>
          <DialogControl Type="Edit" Name="input_dim">
            <Prompt>Input dimension (nonnegative integer)</Prompt>
          </DialogControl>
          <DialogControl Type="Edit" Name="T">
            <Prompt>Flow Horizon (nonnegative real)</Prompt>
          </DialogControl>
          <DialogControl Type="Edit" Name="J">
            <Prompt>Jump Horizon (nonnegative integer)</Prompt>
          </DialogControl>
        </DialogControl>
      </DialogControl>
    </Mask>
    <System Ref="system_646"/>

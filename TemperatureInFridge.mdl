        <P Name="script">function inD  = D(q, u) 
    
    qplus = zeros(size(q)); 
    if u(1) &lt;= 35 
        qplus(1) = 0;
    
    elseif u(1)&gt;=40
        qplus(1) = 1;
    else
        qplus(1)=q(1);
    end
    if q(1)==qplus(1) &amp;&amp; q(2)==qplus(2)
        inD = 0; 
    else

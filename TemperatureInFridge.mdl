  <Block BlockType="SubSystem" Name="FSM" SID="646">
    <PortCounts in="1" out="4"/>
    <P Name="Position">[-180, 124, -115, 191]</P>
    <P Name="ZOrder">15</P>
    <P Name="CopyFcn">set_param(gcb,&apos;LinkStatus&apos;,&apos;none&apos;),                                      
set_param(gcs, &apos;MaxStep&apos;, &apos;MaxStep&apos;, &apos;RelTol&apos;, &apos;RelTol&apos;,&apos;StopTime&apos;, &apos;T&apos;)</P>
    <P Name="LoadFcn">set_param(gcb,&apos;LinkStatus&apos;,&apos;none&apos;)</P>
    <P Name="ContentPreviewEnabled">on</P>
    <Mask>
      <Type>Finite State Machine (FSM)</Type>
      <Display>image(&apos;FSM.jpg&apos;)
port_label(&apos;output&apos;, 1, &apos;q&apos;)
port_label(&apos;output&apos;, 2, &apos;t&apos;)
port_label(&apos;output&apos;, 3, &apos;j&apos;)
port_label(&apos;output&apos;, 4, &apos;q-(int)&apos;)
port_label(&apos;input&apos;, 1, &apos;u&apos;)

</Display>
      <Description>To define the FSM: 
1. Select the block,
2. &quot;Look inside&quot; the block: Either open the context menu and select Mask &gt; Look Under Mask, or click the arrow in the bottom-left corner of the block.
3. Edit the flow set C, jump set D, and jump map g.  </Description>
      <Initialization>state_dim = numel(q0);</Initialization>
      <Help>eval hybrid.internal.openHelp(&apos;CPS_finite_state_machine&apos;)</Help>
      <MaskParameter Name="q0" Type="edit">
        <Prompt>Initial state (column vector)</Prompt>
        <Value>[0; 1]</Value>
      </MaskParameter>
      <MaskParameter Name="input_dim" Type="edit">
        <Prompt>Input dimension (nonnegative integer)</Prompt>
        <Value>1</Value>
      </MaskParameter>
      <MaskParameter Name="T" Type="promote">
        <Prompt>Flow Horizon (nonnegative real)</Prompt>
        <Value>T</Value>
        <TypeOptions>
          <Option>Integrator System/T</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="J" Type="promote">
        <Prompt>Jump Horizon (nonnegative integer)</Prompt>
        <Value>J</Value>
        <TypeOptions>
          <Option>Integrator System/J</Option>
        </TypeOptions>
      </MaskParameter>
